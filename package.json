{
  "name": "pi-grok",
  "version": "0.5.0",
  "description": "Use your SuperGrok subscription in pi with OAuth login, auto-refresh, and live model discovery",
  "keywords": [
    "pi-package",
    "xai",
    "grok",
    "oauth",
    "xai-oauth",
    "grok-oauth"
  ],
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "author": "stnly",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stnly/pi-grok.git"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
